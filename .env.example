# ============================================================
# GLAZZY — Environment Variables Template
# COPY file ini jadi .env.local, lalu isi nilainya
# File ini BOLEH di-commit ke git (tidak ada nilai sensitif)
# ============================================================

# ── Admin Dashboard Auth ─────────────────────────────────────
# Username dan password untuk login admin dashboard
NEXT_PUBLIC_ADMIN_USERNAME=
NEXT_PUBLIC_ADMIN_PASSWORD=

# ── POS Kasir PIN ────────────────────────────────────────────
# PIN 4-digit untuk unlock POS terminal
NEXT_PUBLIC_POS_PIN=

# ── App Info (opsional) ──────────────────────────────────────
# Nama toko dan info lain yang muncul di UI
NEXT_PUBLIC_STORE_NAME=GLAZZY
